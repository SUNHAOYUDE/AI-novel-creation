{
  "name": "ai-novel-creation",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "setup": "powershell -ExecutionPolicy Bypass -File ./scripts/setup.ps1",
    "start:dev": "powershell -ExecutionPolicy Bypass -File ./scripts/start-dev.ps1",
    "start:windows": "powershell -ExecutionPolicy Bypass -File ./scripts/start-dev.ps1",
    "stop:dev": "powershell -ExecutionPolicy Bypass -File ./scripts/stop-dev.ps1",
    "restart:dev": "powershell -ExecutionPolicy Bypass -File ./scripts/restart-dev.ps1",
    "dev:frontend": "npm --prefix frontend run dev",
    "dev:backend": "npm --prefix backend run start:dev",
    "build:frontend": "npm --prefix frontend run build",
    "build:backend": "npm --prefix backend run build",
    "check:frontend": "npm --prefix frontend run check",
    "check:backend": "npm --prefix backend run check"
  }
}
